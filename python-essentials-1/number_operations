try:
    num1 = int(input("Enter the first number: "))
    num2 = int(input("Enter the second number: "))

    print(f"Sum: {num1 + num2}")

    if num2 == 0:
        print("Cannot divide by zero")
    else:
        print(f"Division result: {num1 / num2}")

except ValueError:
    print("Invalid input")