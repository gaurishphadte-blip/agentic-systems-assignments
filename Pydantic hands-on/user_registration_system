import re
from typing import Optional
from pydantic import BaseModel, EmailStr, Field, field_validator, ConfigDict, ValidationError


class Address(BaseModel):
    model_config = ConfigDict(validate_assignment=True)

    city: str = Field(..., min_length=3, description="City name (minimum 3 characters)")
    pincode: str = Field(..., description="Pincode must be exactly 6 digits")

    @field_validator("pincode")
    @classmethod
    def validate_pincode(cls, v: str) -> str:
        if not re.fullmatch(r"\d{6}", v):
            raise ValueError("Pincode must be exactly 6 digits (numeric only)")
        return v


class User(BaseModel):
    model_config = ConfigDict(validate_assignment=True)

    user_id: int
    name: str
    email: EmailStr
    age: int = Field(..., ge=18, description="Age must be 18 or older")
    address: Address
    is_premium: Optional[bool] = False


# ─────────────────────────────────────────────
# Helper to register a user and print results
# ─────────────────────────────────────────────
def register_user(label: str, data: dict):
    print(f"\n{'='*55}")
    print(f"  Test: {label}")
    print(f"{'='*55}")
    try:
        user = User(**data)
        print("✅ Registration Successful!")
        print(f"   User ID    : {user.user_id}")
        print(f"   Name       : {user.name}")
        print(f"   Email      : {user.email}")
        print(f"   Age        : {user.age}")
        print(f"   City       : {user.address.city}")
        print(f"   Pincode    : {user.address.pincode}")
        print(f"   Premium    : {user.is_premium}")
        return user
    except ValidationError as e:
        print("❌ Registration Failed:")
        for err in e.errors():
            loc = " → ".join(str(l) for l in err["loc"])
            print(f"   [{loc}] {err['msg']}")
        return None


# ─────────────────────────────────────────────
# Demo: validate_assignment in action
# ─────────────────────────────────────────────
def demo_assignment_validation(user: User):
    print(f"\n{'='*55}")
    print("  Demo: validate_assignment=True")
    print(f"{'='*55}")

    # Valid re-assignment
    try:
        user.age = 30
        print(f"✅ age updated to 30  → age = {user.age}")
    except ValidationError as e:
        print(f"❌ {e.errors()[0]['msg']}")

    # Invalid re-assignment (age < 18)
    try:
        user.age = 15
        print(f"✅ age updated to 15  → age = {user.age}")
    except ValidationError as e:
        print(f"❌ Cannot set age=15  → {e.errors()[0]['msg']}")

    # Invalid pincode re-assignment
    try:
        user.address.pincode = "ABC"
        print(f"✅ pincode updated    → {user.address.pincode}")
    except ValidationError as e:
        print(f"❌ Cannot set pincode='ABC' → {e.errors()[0]['msg']}")


